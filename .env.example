# ============================================================================
# LeadForge — Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Or run `npm run setup` to fill these in interactively.
# NEVER commit the .env file to version control.
# ============================================================================

# ─── Database (MySQL) ─────────────────────────────────────────────────────────
DB_HOST=localhost
DB_USER=leadforger
DB_PASS=your_database_password_here
DB_NAME=leadforge_db

# ─── Authentication ───────────────────────────────────────────────────────────
# SESSION_SECRET: used to sign session cookies (use a long random string)
SESSION_SECRET=your_random_session_secret_here
# Default admin account created on first startup
ADMIN_USER=admin
ADMIN_PASS=your_admin_password_here

# ─── API Keys ─────────────────────────────────────────────────────────────────
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here
HUNTER_API_KEY=your_hunter_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# ─── SMTP (Email) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password_here
FROM_NAME=Your Name

# ─── Server ───────────────────────────────────────────────────────────────────
# Port the Express server listens on (Plesk will set this automatically)
PORT=3000
